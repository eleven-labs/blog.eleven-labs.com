{
  "name": "blog-eleven-labs",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "prepare": "pnpm ts-node bin/prepare",
    "postinstall": "sh -c 'git rev-parse --is-inside-work-tree >/dev/null 2>&1 && husky || true'",
    "ts-node": "tsx -r dotenv/config",
    "download-translations": "pnpm ts-node bin/downloadTranslations",
    "generate-image-formats": "pnpm ts-node bin/generateImageFormats",
    "validate-markdown": "pnpm ts-node bin/validateMarkdown",
    "indexation:algolia": "pnpm ts-node bin/indexationAlgolia",
    "build": "pnpm ts-node bin/build",
    "prerender": "pnpm build && pnpm ts-node bin/prerender",
    "start:dev": "pnpm ts-node bin/dev",
    "start:prod": "NODE_ENV=production node dist/server",
    "start:static": "npx serv --path dist/public",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"bin/**/*.ts\"",
    "type-check": "pnpm exec tsc --noEmit",
    "test": "vitest --coverage"
  },
  "lint-staged": {
    "*.(ts|tsx)": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">= 20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "node-sass",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@eleven-labs/design-system": "^0.37.3",
    "@remix-run/router": "^1.16.0",
    "algoliasearch": "^4.23.3",
    "classnames": "^2.5.1",
    "copy-to-clipboard": "^3.3.3",
    "cross-fetch": "^4.0.0",
    "date-fns": "^3.6.0",
    "downshift": "^9.0.4",
    "express": "^4.19.2",
    "glob": "^10.3.12",
    "hoofd": "^1.7.1",
    "i18next": "^23.11.3",
    "i18next-browser-languagedetector": "^7.2.1",
    "i18next-http-middleware": "^3.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.1",
    "react-router": "6.30.3",
    "react-router-dom": "^6.23.0",
    "react-share": "^5.1.0",
    "serve-static": "^1.15.0",
    "universal-cookie-express": "^7.1.4",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@eslint/js": "^10.0.0",
    "@rollup/plugin-replace": "^5.0.5",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.6",
    "@types/express": "^4.17.21",
    "@types/gtag.js": "^0.0.19",
    "@types/i18next": "^13.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.1",
    "@types/node": "^20.12.8",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/react-i18next": "^8.1.0",
    "@types/sanitize-html": "^2.11.0",
    "@types/serve-static": "^2.2.0",
    "@types/unist": "^3.0.0",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.5.3",
    "autoprefixer": "^10.4.19",
    "babel-loader": "^9.1.3",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.5",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-perfectionist": "^3.9.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "feed": "^4.2.2",
    "github-slugger": "^2.0.0",
    "globals": "^16.4.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.0.11",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.2",
    "mdast-util-to-string": "^4.0.0",
    "mime": "^4.0.3",
    "node-sass": "^9.0.0",
    "postcss": "^8.4.38",
    "postcss-normalize": "^10.0.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^2.8.8",
    "rehype-raw": "^6.1.1",
    "rehype-react": "^7.2.0",
    "rehype-rewrite": "^3.0.6",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^3.0.1",
    "remark-parse": "^10.0.2",
    "remark-rehype": "^10.1.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "sanitize-html": "^2.13.0",
    "sass": "^1.76.0",
    "sharp": "^0.33.3",
    "stylelint": "^16.5.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "tsx": "^4.9.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.46.4",
    "unified": "^10.1.2",
    "unist-util-visit": "^5.0.0",
    "vite": "^5.2.11",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.5.3",
    "zod": "^3.23.6",
    "zod-validation-error": "^3.2.0"
  }
}
